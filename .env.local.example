# Supabase — copy from your project's API settings
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# Optional: Supabase service role key (server-side only — never expose to client)
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# Optional: OpenAI key for AI-assisted recipe extraction (URL import enhancement)
OPENAI_API_KEY=

# App base URL — set to your Netlify URL in production
NEXT_PUBLIC_APP_URL=http://localhost:3000
